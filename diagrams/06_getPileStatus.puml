@startuml getPileStatus
title 顺序图 - 查询单个充电桩状态

actor 用户 as User
participant "边界层\nApiController" as API
participant "仓库层\nChargingPileRepository" as CPR
participant "仓库层\nQueueRecordRepository" as QRR
participant "仓库层\nRechargeRecordRepository" as RRR

User -> API : GET /api/state\n(前端筛选 pileId 展示单桩)

API -> CPR : findById(pileId)
CPR --> API : Optional<ChargingPile>

alt 桩不存在
    API --> User : 404
else 桩存在
    API -> API : 读取 pile.getState()\npile.getType() / pile.getPower()

    API -> QRR : findByPileIdOrderByPositionAsc(pileId)
    QRR --> API : List<QueueRecord>

    alt 队列非空 (有车辆)
        API -> API : 队首 vehicle = qr.getVehicle()\n读取 vehicle.getId() / getRequestedAmount()

        API -> RRR : findByVehicleId(vehicleId)
        RRR --> API : List<RechargeRecord>

        API -> API : 找到未结束的 RechargeRecord\n读取 chargedAmount / startTime
        API -> API : 组装 PileStatusDTO\n(occupied, vehicleId, chargedKwh,\n pileType, power, state, queueLength)
    else 队列为空 (空闲)
        API -> API : 组装 PileStatusDTO (occupied=false)
    end

    API --> User : 200 OK + 桩状态 JSON
end
@enduml