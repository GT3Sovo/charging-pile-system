@startuml tickChargingProcess
title 顺序图 - 仿真秒推驱动充电进程

actor "用户/仿真" as User
participant "边界层\nApiController" as API
participant "控制层\nSimulationService" as Sim
participant "控制层\nSchedulingEngine" as Sched
participant "控制层\nBillingEngine" as BillEng
participant "仓库层\nChargingPileRepository" as CPR
participant "仓库层\nQueueRecordRepository" as QRR
participant "仓库层\nVehicleRepository" as VR
participant "仓库层\nRechargeRecordRepository" as RRR
participant "仓库层\nDetailListRepository" as DLR
participant "仓库层\nBillRepository" as BR

User -> API : POST /api/sim/tick\n(seconds)
API -> Sim : tick(seconds)
Sim -> Sim : lockMode()
Sim -> Sim : doTick(seconds)

loop 每秒推进 (step++)
    Sim -> Sim : currentSec++
    Sim -> Sim : processRecoveries(stepTime)\n检查故障桩恢复时间
    Sim -> Sim : processChargingSec(stepTime)

    Sim -> CPR : findAll()
    CPR --> Sim : List<ChargingPile>

    loop 每个 RUNNING 充电桩
        Sim -> QRR : findByPileIdOrderByPositionAsc(pileId)
        QRR --> Sim : List<QueueRecord>

        alt 队列非空 (队首车辆)
            Sim -> RRR : findByVehicleId(vehicleId)
            RRR --> Sim : List<RechargeRecord>

            alt 无活跃 RechargeRecord
                Sim -> Sim : new RechargeRecord(vehicle, pile, startTime, 0.0)
                Sim -> RRR : save(record)
            else 已有记录
                Sim -> Sim : deltaQ = min(powerPerSec, 剩余需充电量)\nrecord.chargedAmount += deltaQ
                Sim -> RRR : save(record)

                alt 已充满 (totalCharged >= requestedAmount)
                    Sim -> Sched : finishChargingNoDispatch(vehicleId, stepTime)

                    Sched -> Sched : stopChargingAndGenerateDetail(vehicle, pile, time)
                    Sched -> RRR : findByVehicleId(vehicleId)
                    RRR --> Sched : RechargeRecord
                    Sched -> Sched : 设置 record.endTime = time

                    Sched -> BillEng : calculate(startTime, endTime, chargedAmount)
                    BillEng --> Sched : BillingResult

                    Sched -> Sched : new DetailList(detailNo, ...)
                    Sched -> DLR : save(detail)
                    Sched -> Sched : new Bill / 累加已有 Bill
                    Sched -> BR : save(bill)

                    Sched -> CPR : save(pile)\n(更新累计统计)
                    Sched -> QRR : deleteByVehicleId(vehicleId)
                    Sched -> VR : save(vehicle)\n(state = FINISHED)
                    Sched -> Sched : reorderPileQueue(pileId)
                    Sched -> Sched : startNextVehicleInPile(pile, time)
                end
            end
        end
    end

    Sim -> Sched : tryDispatch(mode, time)
    Sim -> Sim : processEventsAtSec(stepTime)
end

Sim --> API : void
API --> User : 200 "SUCCESS"
@enduml